.env
.env.local
.env.*.local

# Runtime application state
/data/
/backups/
/secrets/
/output/
/ProductionDeployment/runtime/*
!/ProductionDeployment/runtime/.gitkeep
!/ProductionDeployment/runtime/data/
/ProductionDeployment/runtime/data/*
!/ProductionDeployment/runtime/data/.gitkeep
!/ProductionDeployment/runtime/backups/
/ProductionDeployment/runtime/backups/*
!/ProductionDeployment/runtime/backups/.gitkeep
!/ProductionDeployment/runtime/secrets/
/ProductionDeployment/runtime/secrets/*
!/ProductionDeployment/runtime/secrets/.gitkeep

# Build artifacts
*.exe

# Local databases
*.db
*.db-shm
*.db-wal

# Temporary editor / agent / OS artifacts
.codex/
.idea/
.vscode/
.DS_Store
Thumbs.db
*.log
*.tmp
*.swp
*.swo

# Accidental backup artifacts
*.go.[0-9]*
*.html.[0-9]*

# Python
__pycache__/
*.pyc

# Node / browser tooling
node_modules/
playwright-report/
test-results/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
